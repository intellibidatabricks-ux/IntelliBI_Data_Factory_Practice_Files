{
	"name": "ls_sqlserver_param",
	"properties": {
		"parameters": {
			"pLsServerName": {
				"type": "string"
			},
			"pLsDatabasename": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "SqlServer",
		"typeProperties": {
			"server": "@{linkedService().pLsServerName}",
			"database": "@{linkedService().pLsDatabasename}",
			"encrypt": "optional",
			"trustServerCertificate": false,
			"authenticationType": "SQL",
			"userName": "adf_login",
			"password": {
				"type": "AzureKeyVaultSecret",
				"store": {
					"referenceName": "AzureKeyVault",
					"type": "LinkedServiceReference"
				},
				"secretName": "SqlServerPass"
			}
		},
		"connectVia": {
			"referenceName": "shir-local-computer",
			"type": "IntegrationRuntimeReference"
		}
	},
	"type": "Microsoft.DataFactory/factories/linkedservices"
}