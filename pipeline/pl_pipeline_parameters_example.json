{
	"name": "pl_pipeline_parameters_example",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "BinarySource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true
						},
						"formatSettings": {
							"type": "BinaryReadSettings"
						}
					},
					"sink": {
						"type": "BinarySink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "ds_adls_bin_sourcefiles",
						"type": "DatasetReference",
						"parameters": {
							"pDsSourceContainerName": {
								"value": "@pipeline().parameters.pPlSourceContainerName",
								"type": "Expression"
							},
							"pDsSourceFolderPath": {
								"value": "@pipeline().parameters.pPlSourceFolderPath",
								"type": "Expression"
							},
							"pDsSourceFilename": {
								"value": "@pipeline().parameters.pPlSourceFilename",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "ds_adls_bin_targetfiles",
						"type": "DatasetReference",
						"parameters": {
							"pDsTargetContainerName": {
								"value": "@pipeline().parameters.pPlTargetContainerName",
								"type": "Expression"
							},
							"pDsTargetFolderPath": {
								"value": "@pipeline().parameters.pPlTargetFolderPath",
								"type": "Expression"
							},
							"pDsTargetFilename": {
								"value": "@pipeline().parameters.pPlTargetFilename",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"parameters": {
			"pPlSourceContainerName": {
				"type": "string",
				"defaultValue": "cr-clintrail"
			},
			"pPlSourceFolderPath": {
				"type": "string",
				"defaultValue": "sourcefiles/sales"
			},
			"pPlSourceFilename": {
				"type": "string"
			},
			"pPlTargetContainerName": {
				"type": "string",
				"defaultValue": "cr-sink-clintrail"
			},
			"pPlTargetFolderPath": {
				"type": "string",
				"defaultValue": "targetfiles/sales"
			},
			"pPlTargetFilename": {
				"type": "string"
			}
		},
		"folder": {
			"name": "for_each_activity"
		},
		"annotations": [],
		"lastPublishTime": "2026-06-26T02:00:54Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}