{
	"name": "pl_set_variable_activity",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_sourcefiles_param",
						"type": "DatasetReference",
						"parameters": {
							"pDsSourceFolder": {
								"value": "@pipeline().parameters.pSourceFolder",
								"type": "Expression"
							},
							"pDsSourceFile": {
								"value": "@pipeline().parameters.pSourceFile",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "ds_targetfiles_param",
						"type": "DatasetReference",
						"parameters": {
							"pDsTargetFolder": {
								"value": "@pipeline().parameters.pTargetFolder",
								"type": "Expression"
							},
							"pDsSourceFile": {
								"value": "@pipeline().parameters.pTargetFile",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"parameters": {
			"pSourceFolder": {
				"type": "string"
			},
			"pSourceFile": {
				"type": "string"
			},
			"pTargetFolder": {
				"type": "string"
			},
			"pTargetFile": {
				"type": "string"
			}
		},
		"folder": {
			"name": "Azure Data Factory Daily Practice PipeLines/for_each_activity"
		},
		"annotations": [],
		"lastPublishTime": "2026-06-23T02:05:32Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}