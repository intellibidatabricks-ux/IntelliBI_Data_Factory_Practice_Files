{
	"name": "dataflowCustScdType2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "ls_azuresql_clintrail",
						"type": "LinkedServiceReference"
					},
					"name": "sourceCustData"
				},
				{
					"linkedService": {
						"referenceName": "ls_azuresql_clintrail",
						"type": "LinkedServiceReference"
					},
					"name": "sourceLkpCustData"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "ls_azuresql_clintrail",
						"type": "LinkedServiceReference"
					},
					"name": "sinkCustDataInsert"
				},
				{
					"linkedService": {
						"referenceName": "ls_azuresql_clintrail",
						"type": "LinkedServiceReference"
					},
					"name": "sinkCustDataUpdate"
				}
			],
			"transformations": [
				{
					"name": "lookupSrouceTargetCust"
				},
				{
					"name": "selectColumnRename"
				},
				{
					"name": "derivedColumnRowType"
				},
				{
					"name": "alterRowInsertUpdate"
				},
				{
					"name": "splitInsertUpdateRec"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustID as integer,",
				"          CustName as string,",
				"          ProdPurchase as decimal(10,2),",
				"          City as string,",
				"          PhoneNumber as string,",
				"          PurchaseDate as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'SrcCustData',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> sourceCustData",
				"source(output(",
				"          CustSk as long,",
				"          CustID as integer,",
				"          CustName as string,",
				"          ProdPurchase as decimal(10,2),",
				"          City as string,",
				"          PhoneNumber as string,",
				"          PurchaseDate as date,",
				"          IsActive as string,",
				"          RecVer as integer,",
				"          StartEffDate as timestamp,",
				"          EndEffDate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'query',",
				"     store: 'sqlserver',",
				"     query: 'SELECT * FROM dbo.TgtCustDataType2 where IsActive = \\'Y\\'',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> sourceLkpCustData",
				"sourceCustData, sourceLkpCustData lookup(sourceCustData@CustID == sourceLkpCustData@CustID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookupSrouceTargetCust",
				"lookupSrouceTargetCust select(mapColumn(",
				"          SrcCustID = sourceCustData@CustID,",
				"          SrcCustName = sourceCustData@CustName,",
				"          SrcProdPurchase = sourceCustData@ProdPurchase,",
				"          SrcCity = sourceCustData@City,",
				"          SrcPhoneNumber = sourceCustData@PhoneNumber,",
				"          SrcPurchaseDate = sourceCustData@PurchaseDate,",
				"          LkpCustSk = CustSk,",
				"          LkpCustID = sourceLkpCustData@CustID,",
				"          LkpCustName = sourceLkpCustData@CustName,",
				"          LkpProdPurchase = sourceLkpCustData@ProdPurchase,",
				"          LkpCity = sourceLkpCustData@City,",
				"          LkpPhoneNumber = sourceLkpCustData@PhoneNumber,",
				"          LkpPurchaseDate = sourceLkpCustData@PurchaseDate,",
				"          LkpIsActive = IsActive,",
				"          LkpRecVer = RecVer,",
				"          LkpStartEffDate = StartEffDate,",
				"          LkpEndEffDate = EndEffDate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColumnRename",
				"selectColumnRename derive(rowType = iif( isNull(LkpCustID),'Insert',\r",
				"     iif( !isNull(LkpCustID) &&      (SrcCity != LkpCity || SrcPhoneNumber != LkpPhoneNumber) \r",
				"          , 'Update','Reject')),",
				"          dcActiveFlag = 'Y',",
				"          dcInActiveFlag = 'N',",
				"          dcStartEffDateTime = currentTimestamp(),",
				"          dcEndEffDtTime = toDate('31-12-9999', 'dd-MM-yyyy'),",
				"          dcRecVer = iif(isNull(LkpRecVer),1,LkpRecVer+1)) ~> derivedColumnRowType",
				"splitInsertUpdateRec@UpdtRc alterRow(updateIf(rowType=='Update')) ~> alterRowInsertUpdate",
				"derivedColumnRowType split(rowType == 'Insert' || rowType == 'Update',",
				"     rowType == 'Update',",
				"     disjoint: true) ~> splitInsertUpdateRec@(InsRec, UpdtRc)",
				"splitInsertUpdateRec@InsRec sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustSk as long,",
				"          CustID as integer,",
				"          CustName as string,",
				"          ProdPurchase as decimal(10,2),",
				"          City as string,",
				"          PhoneNumber as string,",
				"          PurchaseDate as date,",
				"          IsActive as string,",
				"          RecVer as integer,",
				"          StartEffDate as timestamp,",
				"          EndEffDate as timestamp",
				"     ),",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'TgtCustDataType2',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustID = SrcCustID,",
				"          CustName = SrcCustName,",
				"          RecVer = dcRecVer,",
				"          ProdPurchase = SrcProdPurchase,",
				"          City = SrcCity,",
				"          PhoneNumber = SrcPhoneNumber,",
				"          PurchaseDate = SrcPurchaseDate,",
				"          IsActive = dcActiveFlag,",
				"          StartEffDate = dcStartEffDateTime,",
				"          EndEffDate = dcEndEffDtTime",
				"     )) ~> sinkCustDataInsert",
				"alterRowInsertUpdate sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustSk as long,",
				"          CustID as integer,",
				"          CustName as string,",
				"          ProdPurchase as decimal(10,2),",
				"          City as string,",
				"          PhoneNumber as string,",
				"          PurchaseDate as date,",
				"          IsActive as string,",
				"          RecVer as integer,",
				"          StartEffDate as timestamp,",
				"          EndEffDate as timestamp",
				"     ),",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'TgtCustDataType2',",
				"     insertable: false,",
				"     updateable: true,",
				"     deletable: false,",
				"     upsertable: false,",
				"     keys:['CustSk'],",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustSk = LkpCustSk,",
				"          IsActive = dcInActiveFlag,",
				"          EndEffDate = dcStartEffDateTime",
				"     )) ~> sinkCustDataUpdate"
			]
		}
	}
}